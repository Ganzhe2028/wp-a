generator client {
  provider   = "prisma-client"
  output     = "../app/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Person {
  id           String        @id @default(cuid())
  code         String        @unique
  editToken    String        @unique
  username     String        @unique
  passwordHash String?
  englishName  String?
  chineseName  String?
  grade        String?
  bio          String?
  avatarUrl    String?
  published    Boolean       @default(false)
  hidden       Boolean       @default(false)
  images       Image[]
  favoritesGiven    Favorite[] @relation("Favoriter")
  favoritesReceived Favorite[] @relation("Favoritee")
  location     LocationCard?
  updatedAt    DateTime      @updatedAt
  createdAt    DateTime      @default(now())
}

model Image {
  id        String   @id @default(cuid())
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  url       String
  key       String
  sort      Int      @default(0)
  hidden    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model LocationCard {
  id        String   @id @default(cuid())
  code      String   @unique
  personId  String   @unique
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  name      String
  grade     String?
  room      String
  seat      String
  updatedAt DateTime @updatedAt
}

model Favorite {
  id          String   @id @default(cuid())
  favoriterId String
  favoriteeId String
  favoriter   Person   @relation("Favoriter", fields: [favoriterId], references: [id], onDelete: Cascade)
  favoritee   Person   @relation("Favoritee", fields: [favoriteeId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([favoriterId, favoriteeId])
  @@index([favoriterId])
}

model SystemSetting {
  key   String @id
  value String
}
