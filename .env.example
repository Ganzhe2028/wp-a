# OWeek 个人主页系统 · 环境变量
# 复制此文件为 .env 并填入实际值

# ── 数据库 ──────────────────────────────────────
# Neon PostgreSQL pooled 连接串（查询用）
DATABASE_URL=

# Neon PostgreSQL direct 连接串（仅 prisma migrate）
DIRECT_URL=

# ── 图片存储 (Cloudflare R2) ────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# ── 应用 ────────────────────────────────────────
# 运营后台登录口令
ADMIN_PASSWORD=

# 学生 session 签名密钥，至少 32 字节（256 bit）
# 生成：openssl rand -base64 48
SESSION_SECRET=

# 应用基础 URL（导出链接表时拼接）
# 本地: http://localhost:3000
# 生产: https://your-domain.top
APP_BASE_URL=http://localhost:3000
